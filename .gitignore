# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
*.egg-info/

# Pytest / Coverage
.pytest_cache/
.coverage
htmlcov/

# Environments
.env
.venv
env/
venv/
ENV/

# IDE files
.vscode/
.idea/

# Security-conscious exclusions
# (Ensuring no credentials, keys, or private scans are leaked to public repositories)
secret_keys.txt
secrets.json
*.pem
*.key
credentials.ini
*.log
!sample_auth.log
*.pcap
*.csv
reports/
tmp/
